# eXcalibur frontend — environment template.
# Copy to .env (untracked) and adjust for your deployment.

# MCP endpoint URL.
#
# Cloudflare Pages production:  /mcp  (same-origin via functions/mcp.js proxy)
# Local Vite dev against FastMCP Cloud: https://excalibur-mcp.fastmcp.app/mcp
# Local Vite dev against a local server: http://localhost:8000/mcp
VITE_MCP_URL=/mcp

# Scheduled-post cron Worker public URL (scheduler-worker). Enables the
# owner-private "your scheduler is waiting for your OK" card, which reads the
# Worker's pending proof-request phrase (Device-Grant second surface). Leave
# unset if this FE isn't paired with a Worker — the card simply stays hidden.
#   e.g. https://excalibur-scheduler.<your-account>.workers.dev
VITE_SCHEDULER_URL=
