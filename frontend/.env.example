# eXcalibur frontend — environment template.
# Copy to .env (untracked) and adjust for your deployment.

# MCP endpoint URL.
#
# Cloudflare Pages production:  /mcp  (same-origin via functions/mcp.js proxy)
# Local Vite dev against FastMCP Cloud: https://excalibur-mcp.fastmcp.app/mcp
# Local Vite dev against a local server: http://localhost:8000/mcp
VITE_MCP_URL=/mcp
